# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# LLM served by local Ollama — no API key required
# Ensure Ollama is running: ollama serve
# Pull the model first: ollama pull mistral
OPENCLAW_BASE_URL=http://localhost:11434/v1

# ── LLM model served through Ollama ──────────────────────────────────────────
MODEL_ID=mistral

# ── Alpaca Paper Trading ──────────────────────────────────────────────────────
# Get keys from: https://alpaca.markets (paper trading account)
ALPACA_API_KEY=<your-alpaca-api-key>
ALPACA_SECRET_KEY=<your-alpaca-secret-key>
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Multi-Agent Deliberation ──────────────────────────────────────────────────
# All agents now use local Ollama — no HuggingFace keys needed
# API_KEY_1=hf_<AnalystAgent-key>     # no longer used
# API_KEY_2=hf_<RiskAgent-key>        # no longer used
# API_KEY_3=hf_<ComplianceAgent-key>  # no longer used
# API_KEY_4=hf_<ExecutionAgent-key>   # no longer used

# ── DAP Token Signing Key (HMAC-SHA256) ──────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
DAP_SECRET_KEY=<64-hex-character-random-string>

# ── ArmorIQ (optional — ArmorClaw cloud verification) ────────────────────────
ARMORIQ_API_KEY=<your-armoriq-api-key>
IAP_BACKEND_URL=https://customer-api.armoriq.ai
CSRG_URL=https://customer-iap.armoriq.ai
IAP_ENDPOINT=https://customer-iap.armoriq.ai
PROXY_ENDPOINT=https://customer-proxy.armoriq.ai
BACKEND_ENDPOINT=https://customer-api.armoriq.ai
