# ── OpenClaw / ArmorClaw (AntiGravity) ───────────────────────────────────────
# Start OpenClaw locally before running: openclaw start
OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1
OPENCLAW_GATEWAY=ws://127.0.0.1:18789
OPENCLAW_API_KEY=<your-openclaw-api-key>

# ── LLM model served through OpenClaw ────────────────────────────────────────
MODEL_ID=gpt-oss-120b

# ── Alpaca Paper Trading ──────────────────────────────────────────────────────
# Get keys from: https://alpaca.markets (paper trading account)
ALPACA_API_KEY=<your-alpaca-api-key>
ALPACA_SECRET_KEY=<your-alpaca-secret-key>
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Multi-Agent Deliberation Keys (HuggingFace Inference API) ────────────────
# Each agent is PERMANENTLY assigned one key — do NOT rotate between agents
# Get keys from: https://huggingface.co/settings/tokens
API_KEY_1=hf_<AnalystAgent-key>
API_KEY_2=hf_<RiskAgent-key>
API_KEY_3=hf_<ComplianceAgent-key>
API_KEY_4=hf_<ExecutionAgent-key>

# ── DAP Token Signing Key (HMAC-SHA256) ──────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
DAP_SECRET_KEY=<64-hex-character-random-string>

# ── ArmorIQ (optional — ArmorClaw cloud verification) ────────────────────────
ARMORIQ_API_KEY=<your-armoriq-api-key>
IAP_BACKEND_URL=https://customer-api.armoriq.ai
CSRG_URL=https://customer-iap.armoriq.ai
IAP_ENDPOINT=https://customer-iap.armoriq.ai
PROXY_ENDPOINT=https://customer-proxy.armoriq.ai
BACKEND_ENDPOINT=https://customer-api.armoriq.ai
